{
  "name": "kiro-agent-acp",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.2.0",
  "description": "A Zed ACP adapter for Kiro CLI with model/agent/thinking selection",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "kiro-agent-acp": "dist/index.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./*": "./*"
  },
  "files": [
    "dist/",
    "!dist/tests/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && npm run start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "kiro",
    "acp",
    "zed",
    "agent",
    "editor",
    "agent-client-protocol"
  ],
  "homepage": "https://github.com/todouu/kiro-agent-acp#readme",
  "bugs": {
    "url": "https://github.com/todouu/kiro-agent-acp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/todouu/kiro-agent-acp.git"
  },
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
