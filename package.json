{
  "name": "@anthropic-ai/kiro-agent-acp",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "description": "An ACP-compatible coding agent powered by Kiro CLI (TypeScript)",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "kiro-agent-acp": "dist/index.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./*": "./*"
  },
  "files": [
    "dist/",
    "!dist/tests/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && npm run start",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "kiro",
    "acp",
    "agent",
    "aws",
    "typescript",
    "code",
    "agent-client-protocol"
  ],
  "homepage": "https://github.com/todouu/kiro-agent-acp#readme",
  "bugs": {
    "url": "https://github.com/todouu/kiro-agent-acp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/todouu/kiro-agent-acp.git"
  },
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
